# ==============================================================================
# GravityWorker Environment Variables
# ==============================================================================
# Copy this file to `.env` in the repository root and update the values as needed.
# Note: Do not commit your actual `.env` file containing real secrets to git.

# ------------------------------------------------------------------------------
# 1. AI Engine API Keys
# ------------------------------------------------------------------------------
# API Key for Gemini model runner (required when running with `--agent gemini`)
GEMINI_API_KEY=your_gemini_api_key_here

# ------------------------------------------------------------------------------
# 2. GitHub Integration & Authentication
# ------------------------------------------------------------------------------
# GitHub Personal Access Token or GITHUB_TOKEN for GitHub API access
GITHUB_TOKEN=your_github_token_here

# GitHub App ID for @gravity-worker[bot] identity
GRAVITY_WORKER_APP_ID=your_app_id_here

# GitHub App Private Key (PEM format string or base64 encoded)
GRAVITY_WORKER_PRIVATE_KEY=your_private_key_here

# ------------------------------------------------------------------------------
# 3. Application & Framework Configuration
# ------------------------------------------------------------------------------
# Enable debug mode (true/false)
DEBUG=false

# Secret key for Alexi framework session signing and security
SECRET_KEY=development-secret-key-change-in-production

# ------------------------------------------------------------------------------
# 4. Storage & Database (Deno KV)
# ------------------------------------------------------------------------------
# Optional local Deno KV database file path
# DENO_KV_PATH=./gravity_worker.db

# Optional remote Deno KV database URL (for production environments)
# DENO_KV_URL=https://api.deno.com/databases/...
