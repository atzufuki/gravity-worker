# ==============================================================================
# Herkules Environment Configuration Template
# ==============================================================================
# Copy this file to `.env` and fill in the values for local development or CLI operations.
#
#   cp .env.example .env
#
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. AI Agent Configuration
# ------------------------------------------------------------------------------
# API Key for Google Gemini / Antigravity AI agent runner
# Required when using 'antigravity' or 'gemini' agent engines.
GEMINI_API_KEY=your_gemini_api_key_here

# ------------------------------------------------------------------------------
# 2. GitHub Authentication & App Integration
# ------------------------------------------------------------------------------
# GitHub Personal Access Token (PAT) with repository permissions
# Used for CLI interactions with GitHub APIs and pull request creation.
GITHUB_TOKEN=your_github_token_here

# GitHub App Credentials (Optional - configured automatically via `herkules install`)
# Used for authenticating as the @herkules[bot] GitHub App identity.
HERKULES_APP_ID=
HERKULES_PRIVATE_KEY=
HERKULES_RELAY_URL=https://herkules.atzufuki.deno.net

# ------------------------------------------------------------------------------
# 3. Application & Server Settings
# ------------------------------------------------------------------------------
# Enable debug logging and detailed console output (true/false)
DEBUG=false

# Secret key for cryptographic signing and sessions
SECRET_KEY=development-secret-key-change-in-production

# Server HTTP Port (Default: 8000)
PORT=8000

# ------------------------------------------------------------------------------
# 4. Database Settings (Deno KV)
# ------------------------------------------------------------------------------
# Custom local file path for Deno KV database (Optional)
# DENO_KV_PATH=./data/kv.db

# Remote Deno KV connection URL (Used in production environments)
# DENO_KV_URL=https://api.deno.com/databases/your-db-id/connect

# ------------------------------------------------------------------------------
# 5. CI & Automation Settings (Set automatically in GitHub Actions)
# ------------------------------------------------------------------------------
# Path to GitHub Actions event payload file
# GITHUB_EVENT_PATH=/path/to/event.json

# Repository name in 'owner/repo' format
# GITHUB_REPOSITORY=owner/repository

# GitHub Event Name (e.g., issue_comment, push, pull_request)
# GITHUB_EVENT_NAME=issue_comment

# GitHub actor / trigger user username
# GITHUB_ACTOR=octocat

# Commit SHA triggering the workflow run
# GITHUB_SHA=

# Git reference branch or tag (e.g. refs/heads/main)
# GITHUB_REF=refs/heads/main
